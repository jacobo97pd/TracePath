rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isInboxTypeAllowed(type) {
      return type in [
        'friend_request',
        'friend_accept',
        'friend_challenge',
        'level_challenge',
        'live_duel_invite',
        'system_news'
      ];
    }

    function liveMatchRef(matchId) {
      return get(/databases/$(database)/documents/liveMatches/$(matchId));
    }

    function isLiveMatchParticipant(matchId) {
      return isSignedIn() &&
        request.auth.uid in liveMatchRef(matchId).data.playerUids;
    }

    match /skins_catalog/{skinId} {
      allow read: if true;
      allow write: if false;
    }

    match /shop_coin_packs/{packId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      // Controlled searchable reads:
      // - get by UID for friend/profile metadata
      // - limited list/query (must include limit <= 10 in client queries)
      allow get: if isSignedIn();
      allow list: if isSignedIn() &&
        request.query.limit != null &&
        request.query.limit <= 10;
      allow create, update, delete: if isSelf(uid);

      match /friends/{friendUid} {
        allow read, delete: if isSelf(uid);
        allow create, update: if isSignedIn() &&
          friendUid != uid &&
          request.resource.data.uid == friendUid &&
          (
            isSelf(uid) ||
            (
              request.auth.uid == friendUid &&
              request.auth.uid != uid
            )
          );
      }

      match /incoming_requests/{fromUid} {
        allow read, update, delete: if isSelf(uid);
        allow create: if isSignedIn() &&
          request.auth.uid == fromUid &&
          uid != fromUid &&
          !exists(/databases/$(database)/documents/users/$(uid)/friends/$(fromUid)) &&
          !exists(/databases/$(database)/documents/users/$(uid)/incoming_requests/$(fromUid));
      }

      match /sent_requests/{targetUid} {
        allow read, update: if isSelf(uid);
        allow delete: if isSelf(uid) || (
          isSignedIn() &&
          request.auth.uid == targetUid
        );
        allow create: if isSelf(uid) &&
          targetUid != uid &&
          request.resource.data.fromUid == uid &&
          request.resource.data.toUid == targetUid &&
          !exists(/databases/$(database)/documents/users/$(uid)/friends/$(targetUid)) &&
          !exists(/databases/$(database)/documents/users/$(uid)/sent_requests/$(targetUid)) &&
          !exists(/databases/$(database)/documents/users/$(uid)/incoming_requests/$(targetUid));
      }

      match /inbox/{messageId} {
        allow read, delete: if isSelf(uid);
        allow create: if isSignedIn() && (
          request.auth.uid == uid ||
          (
            request.auth.uid != uid &&
            request.resource.data.fromUid == request.auth.uid &&
            isInboxTypeAllowed(request.resource.data.type)
          )
        );
        allow update: if isSelf(uid) || (
          isSignedIn() &&
          request.auth.uid != uid &&
          request.resource.data.fromUid == request.auth.uid &&
          resource.data.fromUid == request.auth.uid &&
          isInboxTypeAllowed(request.resource.data.type) &&
          isInboxTypeAllowed(resource.data.type)
        );
      }

      match /owned_skins/{skinId} {
        allow read, write: if isSelf(uid);
      }

      match /owned_trails/{trailId} {
        allow read, write: if isSelf(uid);
      }

      match /wallet_transactions/{transactionId} {
        allow read, write: if isSelf(uid);
      }

      match /purchases/{purchaseId} {
        allow read, write: if isSelf(uid);
      }

      match /completed_levels/{levelId} {
        allow read, write: if isSelf(uid);
      }

      match /level_rewards/{levelId} {
        allow read, write: if isSelf(uid);
      }

      match /achievements/{achievementId} {
        allow read, write: if isSelf(uid);
      }
    }

    // Username and email lookup indexes for social search.
    match /usernames/{usernameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /emails/{emailLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /leaderboards/{levelId}/scores/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /liveMatches/{matchId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.playerUids;

      allow create: if isSignedIn() &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.invitedUid != request.auth.uid &&
        request.resource.data.playerUids.size() == 2 &&
        request.auth.uid in request.resource.data.playerUids;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.playerUids &&
        // Match identity fields are immutable.
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.invitedUid == resource.data.invitedUid &&
        request.resource.data.levelId == resource.data.levelId &&
        (
          resource.data.packId == null ||
          request.resource.data.packId == resource.data.packId
        ) &&
        (
          resource.data.levelIndex == null ||
          request.resource.data.levelIndex == resource.data.levelIndex
        ) &&
        request.resource.data.playerUids == resource.data.playerUids &&
        (
          resource.data.playerAUid == null ||
          request.resource.data.playerAUid == resource.data.playerAUid
        ) &&
        (
          resource.data.playerBUid == null ||
          request.resource.data.playerBUid == resource.data.playerBUid
        ) &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // Winner is write-once.
        (
          resource.data.winnerUid == '' ||
          request.resource.data.winnerUid == resource.data.winnerUid
        ) &&
        // Limit editable keys on the match root.
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'readyA',
          'readyB',
          'acceptedAt',
          'startAtMs',
          'winnerUid',
          'loserUid',
          'reason',
          'finishedAt',
          'resultResolvedAt',
          'playerATimeMs',
          'playerBTimeMs',
          'playerAName',
          'playerBName'
        ]);

      allow delete: if false;

      match /players/{uid} {
        allow read: if isLiveMatchParticipant(matchId);

        // Each user can only write their own player subdocument.
        allow create: if isLiveMatchParticipant(matchId) &&
          request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.keys().hasOnly([
            'uid',
            'username',
            'avatarId',
            'state',
            'joinedAt',
            'finishedAtMsFromStart',
            'completed',
            'resultPlace',
            'finishedAt'
          ]);

        allow update: if isLiveMatchParticipant(matchId) &&
          request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'uid',
            'username',
            'avatarId',
            'state',
            'joinedAt',
            'finishedAtMsFromStart',
            'completed',
            'resultPlace',
            'finishedAt',
            'lastEmoteAtMs'
          ]);

        allow delete: if false;
      }

      match /realtime/{uid} {
        allow read: if isLiveMatchParticipant(matchId);
        allow create: if isLiveMatchParticipant(matchId) &&
          request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.keys().hasOnly([
            'uid',
            'pathCells',
            'state',
            'pathVersion',
            'updatedAt'
          ]);
        allow update: if isLiveMatchParticipant(matchId) &&
          request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'uid',
            'pathCells',
            'state',
            'pathVersion',
            'updatedAt'
          ]);
        allow delete: if false;
      }

      match /postMatchEmotes/{emoteId} {
        allow read: if isLiveMatchParticipant(matchId);
        allow create: if isLiveMatchParticipant(matchId) &&
          request.resource.data.sentByUid == request.auth.uid &&
          request.resource.data.emoteId is string &&
          request.resource.data.emoteId.size() > 0 &&
          request.resource.data.emoteId.size() <= 24;
        allow update, delete: if false;
      }
    }

    match /friend_challenges/{challengeId} {
      allow create: if isSignedIn() &&
        request.resource.data.challengerUserId == request.auth.uid &&
        request.resource.data.challengedUserId != request.auth.uid &&
        request.resource.data.mode == 'friend_challenge';

      allow read: if isSignedIn() && (
        resource.data.challengerUserId == request.auth.uid ||
        resource.data.challengedUserId == request.auth.uid
      );

      allow update: if isSignedIn() && (
        resource.data.challengerUserId == request.auth.uid ||
        resource.data.challengedUserId == request.auth.uid
      );

      allow delete: if false;
    }

    match /friend_challenge_results/{resultId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.mode == 'friend_challenge';

      allow read, update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
